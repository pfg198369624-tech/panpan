# App
APP_NAME=AppReviewInsights
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret

# Database (MySQL 8.0)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=app_review_insights
DB_USER=root
DB_PASSWORD=your_password

# AI - 火山方舟 (Doubao)
VOLC_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
VOLC_MODEL_NAME=deepseek-v4-flash-260425
VOLC_API_KEY=your_api_key

# AI params
AI_TIMEOUT=300
AI_MAX_RETRIES=2
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192

# Collection
COLLECTION_MAX_PAGES=1
COLLECTION_PAGE_SIZE=50
COLLECTION_RATE_LIMIT=1.0

# Workflow
WORKFLOW_MAX_REFLECTION_ROUNDS=3
WORKFLOW_MAX_RETRY_PER_STEP=1
WORKFLOW_TOTAL_STEPS=7

# Server
CORS_ORIGINS=*

# Database pool
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20

# AI cost
AI_COST_PER_TOKEN=0.000001
AI_BACKOFF_BASE=2
CLASSIFIER_BATCH_SIZE=20

# Collection
COLLECTION_HTTP_TIMEOUT=10
ITUNES_RSS_URL=https://itunes.apple.com/us/rss/customerreviews/page={page}/id={appId}/sortby=mostrecent/json?limit=20
DEFAULT_COUNTRY=us
